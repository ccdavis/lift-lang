// Test 4: Multiple heap allocations per iteration (stress test)
output('Test 4: Multiple lists per iteration');
let var n = 0;
while n < 3 {
    let a: List of Int = [1, 2, 3];
    let b: List of Int = [4, 5, 6];
    let c: List of Int = [7, 8, 9];
    n := n + 1
};
output('Loop 4 complete');

output('All tests complete');
