// Test for memory leak bug: let in while loop creates new heap objects each iteration
// Expected behavior: Previous iteration's objects should be released
// Bug: While loop with let creates new objects each iteration without releasing old ones

// Test 1: List in while loop - should allocate 10 lists, release 9, keep 1
output('Test 1: List in while loop');
let var i = 0;
while i < 10 {
    let y: List of Int = [i, i + 1, i + 2];
    i := i + 1
};
output('Loop 1 complete');

// Test 2: Map in while loop
output('Test 2: Map in while loop');
let var j = 0;
while j < 5 {
    let m: Map of Str to Int = #{'key': j};
    j := j + 1
};
output('Loop 2 complete');

